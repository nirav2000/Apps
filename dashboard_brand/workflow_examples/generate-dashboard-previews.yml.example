name: Generate Dashboard Previews (Example)

on:
  workflow_dispatch:
  push:
    paths:
      - 'dashboard_brand/**'

jobs:
  generate:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: '3.11'
      - name: Generate previews
        run: python dashboard_brand/generate_previews.py
